# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Mediastack API key — https://mediastack.com/
MEDIASTACK_API_KEY=

# IUCN Red List API token — https://api.iucnredlist.org/
IUCN_TOKEN=

# Algorand Testnet mnemonic (25-word phrase)
# Generate with: python -c "from algosdk import account, mnemonic; k,a = account.generate_account(); print(mnemonic.from_private_key(k))"
ALGORAND_MNEMONIC=

# Sentry DSN for error tracking — https://sentry.io/ (leave blank to disable)
SENTRY_DSN=

# PostgreSQL connection string (leave blank to use SQLite locally)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=
